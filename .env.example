SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optionnel : active POST /v1/setup-admin (désactivé par défaut si absent).
# Le compte admin est déjà provisionné automatiquement au démarrage via
# ADMIN_EMAIL / ADMIN_USERNAME / ADMIN_PASSWORD, cet endpoint n'est qu'un secours.
# ADMIN_SETUP_KEY=

DATABASE_URL=postgresql://admin:Password1234@postgres/ticketdb
CORS_ORIGINS=http://localhost:3005,http://localhost:3000

# Rate limiting (slowapi). "memory://" fonctionne sans dépendance externe mais est
# local à l'instance (à revoir si l'app est scalée sur plusieurs instances Render :
# pointer vers le Redis de docker-compose, ex. redis://redis:6379).
RATE_LIMIT_STORAGE_URI=memory://
LOGIN_RATE_LIMIT=5/minute
ASK_RATE_LIMIT=20/minute
RESEND_VERIFICATION_RATE_LIMIT=3/hour
FORGOT_PASSWORD_RATE_LIMIT=3/hour
REGISTER_RATE_LIMIT=5/hour
GUEST_SESSION_RATE_LIMIT=10/hour

# Chat anonyme B2B2C (POST /v1/sessions/guest) : compte "fantôme" créé silencieusement,
# jamais réclamé (email/mot de passe réels via POST /v1/me/claim) au-delà de ce délai =
# purgé automatiquement par le scheduler RGPD existant.
GUEST_ACCOUNT_TTL_DAYS=7

# Vérification d'email à l'inscription + réinitialisation de mot de passe. FRONTEND_URL
# sert à construire les liens envoyés (ex: https://smartticket.exemple.com). Sans
# BREVO_API_KEY ni SMTP_HOST configurés, le lien est simplement loggué au lieu d'être
# envoyé (dev local / tests) — aucun compte email requis en dev.
FRONTEND_URL=http://localhost:3005
EMAIL_VERIFICATION_EXPIRE_HOURS=48
PASSWORD_RESET_EXPIRE_MINUTES=60

# Option recommandée sur Render : API HTTP Brevo (passe par HTTPS, aucun blocage de
# port/IP possible côté hébergeur, contrairement au SMTP classique). Prioritaire sur
# SMTP_HOST si les deux sont définis. Clé dans Brevo → SMTP et API → Clés API et MCP.
BREVO_API_KEY=

# Repli SMTP générique (Brevo, SendGrid, Mailgun, Gmail avec mot de passe d'application...)
# si BREVO_API_KEY n'est pas défini. Sur Render, le port 587 est fréquemment bloqué en
# sortie : essayer 2525 (supporté par Brevo) en cas de timeout de connexion. Vérifier
# aussi qu'aucune restriction "IPs autorisées" n'est active côté fournisseur SMTP, Render
# n'ayant pas d'IP de sortie fixe sur les plans standards.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
EMBED_MODEL=mistral-embed
EMBEDDING_DIMENSION=1024
EMBED_BATCH_SIZE=8
MISTRAL_MAX_RETRIES=5
MISTRAL_BACKOFF_SECONDS=2

REQUEST_TIMEOUT=30
SCRAPE_TIMEOUT=10
KB_TOP_K=4
KB_MAX_CONTEXT_CHARS=3000

# Indexer le transcript/résumé d'un ticket clos dans la base de connaissances partagée
# expose son contenu aux futures questions de n'importe quel autre utilisateur. Acceptable
# en usage B2B interne (collègues de confiance) ; risque de fuite entre clients finaux en
# B2B2C (support public) — désactivé par défaut, à activer explicitement si pertinent.
INDEX_CLOSED_TICKETS=false

# Reranking RAG : sur-échantillonne KB_TOP_K * RERANK_FETCH_MULTIPLIER candidats
# par similarité cosinus, puis reclasse par similarité + recouvrement lexical +
# feedback utilisateur accumulé par chunk. RERANK_QUARANTINE_THRESHOLD exclut tout
# chunk dont le feedback net (somme des 1/-1) descend à ce seuil ou en dessous.
RERANK_FETCH_MULTIPLIER=3
RERANK_LEXICAL_WEIGHT=0.3
RERANK_FEEDBACK_WEIGHT=0.2
RERANK_QUARANTINE_THRESHOLD=-3
SUMMARY_MAX_CHARS=4000
SUMMARY_MAX_MESSAGES=50
TRANSCRIPT_MAX_CHARS=12000
TRANSCRIPT_CHUNK_SIZE=1000
TRANSCRIPT_CHUNK_OVERLAP=150
MAX_SITEMAP_URLS=10
MAX_KB_CHUNKS=80
MIN_TEXT_LENGTH=80
MAX_WEIRD_CHAR_RATIO=0.2
KB_CATEGORY=site_web
